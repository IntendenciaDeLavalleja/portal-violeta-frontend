---
import "@/styles/global.css";
import { Navbar } from "@/components/islands/Navbar";
import { HeroUrgente } from "@/components/islands/HeroUrgente";
import { QuickActions } from "@/components/islands/QuickActions";
import { InfoCards } from "@/components/islands/InfoCards";
import { ResourcesLocator } from "@/components/islands/ResourcesLocator";
import { ContactForm } from "@/components/islands/ContactForm";
import { Footer } from "@/components/islands/Footer";
import { ToastProvider } from "@/components/islands/ToastProvider";
import { ViewTransitions } from "astro:transitions";

// Server-side logic if needed
---

<html lang="es" class="dark scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<meta name="generator" content={Astro.generator} />
		<ViewTransitions />
		<title>Portal Violeta | Ayuda y Orientación</title>
		<link rel="canonical" href={Astro.url.href} />
		<meta name="description" content="Espacio seguro de orientación y apoyo en situaciones de violencia. Ayuda inmediata, recursos y contacto seguro." />
		<meta name="keywords" content="punto violeta, ayuda violencia de género, orientación, recursos sociales, apoyo, protección" />
		<meta name="theme-color" content="#2e1065" />

		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:site_name" content="Portal Violeta" />
		<meta property="og:locale" content="es_UY" />
		<meta property="og:title" content="Portal Violeta | Ayuda y Orientación" />
		<meta property="og:description" content="Espacio seguro de orientación y apoyo en situaciones de violencia. Ayuda inmediata, recursos y contacto seguro." />
		<meta property="og:image" content={new URL("/Opengraph.webp", Astro.site).href} />
		<meta property="og:image:secure_url" content={new URL("/Opengraph.webp", Astro.site).href} />
		<meta property="og:image:type" content="image/webp" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Portal Violeta Lavalleja — Espacio seguro de ayuda y orientación" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url.href} />
		<meta name="twitter:title" content="Portal Violeta | Ayuda y Orientación" />
		<meta name="twitter:description" content="Espacio seguro de orientación y apoyo en situaciones de violencia. Ayuda inmediata, recursos y contacto seguro." />
		<meta name="twitter:image" content={new URL("/Opengraph.webp", Astro.site).href} />
		<meta name="twitter:image:alt" content="Portal Violeta Lavalleja — Espacio seguro de ayuda y orientación" />

		<link 
			rel="stylesheet" 
			href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" 
			integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" 
			crossorigin="" 
		/>
	</head>
	<body class="bg-background text-foreground min-h-screen font-sans antialiased selection:bg-primary selection:text-primary-foreground">
		
		{/* Toast Notifications */}
		<ToastProvider client:idle />

		{/* Main Layout */}
		<div class="relative flex flex-col min-h-screen pb-20 md:pb-0">
			
			<Navbar client:load />

			<main class="flex-1">
				<HeroUrgente client:load />
				<QuickActions client:visible />
				<InfoCards client:visible />
				<ResourcesLocator client:visible />
				<ContactForm client:visible />
			</main>

			<Footer client:visible />
		</div>

	</body>
</html>
