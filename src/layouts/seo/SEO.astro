---
/**
 * Componente SEO para gestionar metadatos, Open Graph y Twitter Cards.
 */

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "Camping Arequita | Disfruta la Naturaleza en Lavalleja, Uruguay",
  description = "Descubre el Camping Arequita en Lavalleja, Uruguay. Reserva cabañas exclusivas, espacios para motorhome y parcelas para acampar con todos los servicios. Disfruta de piscinas, parrilleros, y más en plena naturaleza.",
  keywords = "camping, arequita, minas, lavalleja, uruguay, cerro arequita, cabañas, motorhome, parcelas para acampar, piscinas, turismo, naturaleza, reserva, vacaciones, aire libre, ecoturismo",
  image = "/og-image.webp", // Hemos movido la imagen webp a public/og-image.webp
  canonicalURL = Astro.url.href,
} = Astro.props;

// Combinar el título si es necesario
const formattedTitle = title.includes("Camping Arequita") ? title : `${title} | Camping Arequita`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Campground",
  "name": "Camping Arequita",
  "image": new URL(image, Astro.url).toString(),
  "description": description,
  "url": canonicalURL,
  "telephone": "+598 4442 8056", // Teléfono de ejemplo (ajustar si es necesario)
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Ruta 12 km 10", // Dirección de ejemplo (ajustar)
    "addressLocality": "Minas",
    "addressRegion": "Lavalleja",
    "addressCountry": "UY"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -34.2936, // Coordenadas aproximadas
    "longitude": -55.2754
  },
  "priceRange": "$$",
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Cabañas equipadas", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Parcelas con electricidad", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Piscina techada y abierta", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Parrilleros", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Juegos infantiles", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Wi-Fi", "value": true }
  ]
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{formattedTitle}</title>
<meta name="title" content={formattedTitle} />
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />

<!-- Open Graph / Facebook -->
<!-- Ayuda a controlar cómo se muestra el enlace cuando se comparte en FB o WhatsApp -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<!-- Ayuda a controlar cómo se muestra el enlace en Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={formattedTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Sitemap -->
<!-- Enlace al mapa del sitio para rastreadores -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Robots -->
<!-- Permite que los buscadores indexen el sitio -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- Structured Data / JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
